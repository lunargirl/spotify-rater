# Spotify Developer Dashboard — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Optional locally — derived from NEXT_PUBLIC_APP_URL on Vercel if omitted
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# App URL (use 127.0.0.1, not localhost, for OAuth cookies)
# On Vercel you can omit this; VERCEL_URL is used automatically after deploy
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: set to true when developing over plain HTTP
# FORCE_INSECURE_COOKIES=true

# Listening history — hourly background sync (cron-job.org → POST /api/listening/sync-cron)
# Generate: openssl rand -hex 32
# Vercel: add CRON_SECRET for Production, then redeploy. cron-job.org header:
#   Authorization: Bearer <paste CRON_SECRET here>
# Or URL: .../api/listening/sync-cron?secret=<CRON_SECRET>
CRON_SECRET=

# Optional: separate secret for encrypting stored Spotify refresh tokens (defaults to SUPABASE_SERVICE_ROLE_KEY)
# LISTENING_TOKEN_SECRET=
